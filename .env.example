#####################################################################
#                       GEMINI API CONFIGURATION                    #
#####################################################################

# 🔑 API Keys (Keep only ONE active key at a time)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY='your-gemini-api-key-here' 

# 🔄 Optional: Multiple API Keys for Rotation & Rate Limit Management
# Uncomment and add additional keys to enable automatic rotation when limits are hit
# GEMINI_API_KEY_1='your-second-api-key-here'
# GEMINI_API_KEY_2='your-third-api-key-here'
# GEMINI_API_KEY_3='your-fourth-api-key-here'
# Add as many as needed (GEMINI_API_KEY_4, GEMINI_API_KEY_5, etc.)

# 🤖 Model Settings
# gemini-2.5-flash is generally the best choice for fast, high-quality general tasks.
GEMINI_MODEL='gemini-2.5-flash' 

# 💡 Generation Configuration (Optional - Uncomment and set values to use)
# GEMINI_TEMPERATURE=1.00    # Controls randomness. 0.0 for deterministic results.
# GEMINI_TOP_P=0.99          # Nucleus sampling probability.
# GEMINI_TOP_K=1             # Top-k sampling.
# GEMINI_MAX_OUTPUT_TOKENS=8100
# GEMINI_STOP_SEQUENCES='\n\n' # Sequences that stop generation.

# 📋 List of Available Models (For Reference)
# Note: In a real environment, this array is often defined in code, not in .env.
# GEMINI_MODEL_OPTIONS=(
#   'gemini-2.0-flash-lite'
#   'gemini-2.5-flash'
#   'gemini-2.5-flash-lite'
#   'gemini-2.5-pro'
#   'gemini-3-flash'
# )

#####################################################################
#                     HUGGING FACE CONFIGURATION                    #
#####################################################################

# 🔑 API Key
# Get your API key from: https://huggingface.co/settings/tokens
HF_API_KEY='your-huggingface-api-key-here'

#####################################################################
#                       GROQ CONFIGURATION                          #
#####################################################################

# 🔑 API Key (for desktop version)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY='your-groq-api-key-here'

#####################################################################
#                     SUPABASE CONFIGURATION                        #
#####################################################################

# Get these from your Supabase project settings
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_URL=https://your-project.supabase.co

#####################################################################
#                        Backend Config                             #
#####################################################################

# Options: gemini, huggingface
DEFAULT_BACKEND=gemini
